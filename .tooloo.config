{
  "project_name": "tooloo-simulated-client",
  "description": "Simulated client for TooLoo integration testing — a TaskFlow task-management API",
  "stack": "Python / FastAPI / SQLite / SQLAlchemy",
  "main_language": "python",
  "framework": "fastapi",
  "database": "sqlite",
  "mcp_server_port": 7000,
  "entry_point": "main.py",
  "test_command": "pytest tests/ -v",
  "start_command": "uvicorn main:app --reload --port 8001",
  "mcp_server_command": "python product_mcp_server.py",
  "known_issues": [
    "priority field accepts any string — no enum validation",
    "DELETE /tasks/{id} returns 200 even for non-existent tasks",
    "N+1 query in /users/{id}/tasks — filters in Python instead of SQL",
    "updated_at never populated on PATCH",
    "No global exception handler for unhandled DB errors"
  ]
}
